# App Configuration
NODE_ENV=development
PORT=3000
APP_ALLOWED_ORIGINS=http://localhost:5173

# DB Configuration
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=

# Auth (Better Auth) Configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=supersecretkey

# Email Configuration
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_EMAIL_FROM=no-reply@tudominio.com

# Google AI — asistente clínico, plantillas IA, generación de documentos
# SECRET_KEY_GEMINI es el nombre canónico; GEMINI_API_KEY se acepta por compatibilidad.
SECRET_KEY_GEMINI=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
